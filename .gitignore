# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
test-*.js
test-*.ts
*.test.js
*.test.ts
*.spec.js
*.spec.ts
!src/**/__tests__/**/*.test.ts
!src/**/__tests__/**/*.spec.ts

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.claude/

# documentation - ignore all markdown files except README
*.md
!README.md
!CONTRIBUTING.md
!SECURITY.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# secret files - NEVER commit
API_keys.txt
*.secret
*.key

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Git worktrees
.worktrees/

# local MCP state
/.playwright-mcp/

# local vendor repos
/vendor/antigravity-kit/

# local cloned repos
/autoresearch/autoresearch/

# local autoresearch runtime outputs
/autoresearch/results.tsv
/autoresearch/reports/

# allow tracked autoresearch docs
!autoresearch/*.md
!autoresearch/**/*.md
