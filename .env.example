# ================================================================
# DevTrends environment variables
# ================================================================
# Copy this file to .env.local and fill in the values you need.
# Do not commit .env.local.
#
# This template is aligned with env vars currently read by the app.
# Public or keyless sources are configured in code and do not appear here.
# ================================================================


# --------------------------------------------------
# Core app / Supabase
# --------------------------------------------------
# Get these from Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional override for cron fan-out base URL outside Vercel.
# Example: http://127.0.0.1:3000 or https://devtrends.dev
NEXT_PUBLIC_APP_URL=


# --------------------------------------------------
# Source APIs used by the daily and weekly pipelines
# --------------------------------------------------

# GitHub token for repository and language stats
GITHUB_TOKEN=

# Stack Overflow API key
STACKOVERFLOW_API_KEY=

# Reddit OAuth app credentials
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=DevTrends/1.0

# Dev.to API key (optional; public access still works)
DEVTO_API_KEY=

# Jobs providers
ADZUNA_APP_ID=
ADZUNA_API_KEY=
RAPIDAPI_KEY=
HASDATA_API_KEY=
SERPAPI_API_KEY=

# Optional guardrails for jobs intelligence cost / runtime
JOBS_INTELLIGENCE_MAX_TECHS=20
JOBS_INTELLIGENCE_MAX_MARKETS=3
JOBS_INTELLIGENCE_PAGES_PER_TECH=1
JOBS_TRENDS_MAX_TECHS=40

# Package / ecosystem sources
LIBRARIESIO_API_KEY=

# YouTube data
YOUTUBE_API_KEY=

# Blockchain / market data helpers
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=


# --------------------------------------------------
# AI provider keys
# --------------------------------------------------
# The current key manager supports the providers below.
# Configure one or more depending on the features you want to run.

GEMINI_API_KEY=
GEMINI_API_KEY_2=
GROQ_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=


# --------------------------------------------------
# Admin / protected routes
# --------------------------------------------------
# Used by admin-only endpoints guarded in src/lib/http/route-guards.ts
ADMIN_API_SECRET=


# --------------------------------------------------
# Deployment / cron auth
# --------------------------------------------------
# Required in production for scheduled routes and internal cron fan-out.
CRON_SECRET=

# Set automatically by Vercel. Leave blank locally unless you need them.
# VERCEL_URL=
# VERCEL_ENV=
